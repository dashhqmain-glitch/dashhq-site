# ── Discord OAuth application ─────────────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
# Copy the Client ID and Client Secret from the OAuth2 page
DISCORD_CLIENT_ID=your_app_client_id
DISCORD_CLIENT_SECRET=your_app_client_secret

# The callback URL you registered in the Discord app's OAuth2 Redirects list
# Dev:  http://localhost:8000/auth/discord/callback
# Prod: https://api.dashhq.site/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback

# ── Dash HQ Discord server ────────────────────────────────────────────────────
# Right-click your server icon → Copy Server ID (Developer Mode must be on)
DISCORD_GUILD_ID=your_discord_server_id

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_string

# ── Frontend origin ───────────────────────────────────────────────────────────
# Dev:  http://localhost:3000  (or whatever port you serve the site on)
# Prod: https://dashhq.site
FRONTEND_URL=http://localhost:3000

# ── Optional: Discord bot token ───────────────────────────────────────────────
# Needed for role-based tier detection (Gold / Silver).
# Add the bot to your server with the Members intent enabled.
# Bot token is on the Bot page of your Discord app.
DISCORD_BOT_TOKEN=

# ── Optional: role IDs for tier detection ─────────────────────────────────────
# Right-click a role in Server Settings → Copy Role ID
TIER_GOLD_ROLE_ID=
TIER_SILVER_ROLE_ID=
