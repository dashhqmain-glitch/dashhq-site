# ── Discord OAuth application ─────────────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
# Copy the Client ID and Client Secret from the OAuth2 page
DISCORD_CLIENT_ID=your_app_client_id
DISCORD_CLIENT_SECRET=your_app_client_secret

# The callback URL you registered in the Discord app's OAuth2 Redirects list
# Dev:  http://localhost:8000/auth/discord/callback
# Prod: https://api.dashhq.site/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback

# ── Dash HQ Discord server ────────────────────────────────────────────────────
# Right-click your server icon → Copy Server ID (Developer Mode must be on)
DISCORD_GUILD_ID=your_discord_server_id

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_string

# ── Frontend origin ───────────────────────────────────────────────────────────
# Dev:  http://localhost:3000  (or whatever port you serve the site on)
# Prod: https://dashhq.site
FRONTEND_URL=http://localhost:3000

# ── Optional: Discord bot token ───────────────────────────────────────────────
# Needed for role-based tier detection (Gold / Silver).
# Add the bot to your server with the Members intent enabled.
# Bot token is on the Bot page of your Discord app.
DISCORD_BOT_TOKEN=

# ── Optional: Citizen role ID ──────────────────────────────────────────────────
# Right-click the "Dash Citizen" role in Server Settings → Roles → Copy Role ID.
# If set, portal login requires holding this role (not just guild presence).
CITIZEN_ROLE_ID=

# ── Supabase (member sync storage) ────────────────────────────────────────────
# Project Settings → API on your Supabase project.
# Use the service_role secret key, NOT the anon key — the sync endpoint needs
# to bypass row-level security to write. Run backend/schema.sql once in the
# Supabase SQL Editor before the sync endpoint is used for the first time.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron secret (protects the member-sync endpoint) ───────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same value in Vercel's env vars — Vercel automatically sends it as
# "Authorization: Bearer <CRON_SECRET>" when it triggers the scheduled sync,
# so only Vercel's own cron (and you, manually, for testing) can call it.
CRON_SECRET=
